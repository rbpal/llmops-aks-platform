# Copy to terraform.tfvars (gitignored) and fill. Real values live in
# privatedocs/azure-tfvars-draft.tfvars (outside the repo).

# --- identity (from `az account show`) ---
subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"

# --- core ---
environment = "dev"
location    = "eastus2"
owner       = "your-alias"
name_suffix = "youralias" # in resource names; short, lowercase, alphanumeric

# --- AKS (1->3 autoscale) ---
node_min_count = 1
node_max_count = 3
node_vm_size   = "Standard_D2s_v3"

# --- Azure AI Search ---
search_sku = "free" # "basic" if the free service is already used in this subscription

# --- Azure OpenAI ---
openai_account_name       = "aoai-aaf-dev"
openai_model_version      = "2024-11-20"
openai_model_capacity_tpm = 10

# --- FinOps budget alert ---
operator_email    = "you@example.com"
budget_amount_usd = 50
budget_start_date = "2026-06-01T00:00:00Z" # first of a month, UTC
