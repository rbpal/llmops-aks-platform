# Copy to .env (gitignored). step_00_task02.
LLM_PROVIDER=azure_openai          # azure_openai | anthropic

# Azure OpenAI (Foundry)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-11-20
CHAT_DEPLOYMENT=
EMBEDDING_DEPLOYMENT=

# Anthropic (Claude) — add later
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# RAG
VECTOR_STORE=faiss                 # faiss | azure_search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=corpus

# PII vault (decision: key_vault primary)
VAULT_BACKEND=local                # local | key_vault
VAULT_PATH=data/vault/vault.json
KEY_VAULT_URI=
IS_AUTHORIZED=false
